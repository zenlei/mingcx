{
  "name": "online-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/start-local.mjs",
    "local": "node scripts/start-local.mjs",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "worker:check": "tsc -p workers/sub2api-monitor/tsconfig.json --noEmit",
    "worker:dev": "wrangler dev --config workers/sub2api-monitor/wrangler.toml",
    "worker:deploy": "wrangler deploy --config workers/sub2api-monitor/wrangler.toml",
    "api:dev": "node scripts/sub2api-monitor-local.mjs",
    "monitor:dev": "node scripts/start-monitor-local.mjs"
  },
  "dependencies": {
    "astro": "^6.4.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
