---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "一个本地运行的个人小工具箱。" } = Astro.props;
const siteTitle = "Ming's Tools";
const pageTitle = title === siteTitle ? title : `${title} - ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-brand" href="/" aria-label="回到主页">
        <span class="brand-mark">MT</span>
        <span>
          <strong>Ming's Tools</strong>
        </span>
      </a>
    </header>
    <slot />
    <footer class="site-footer">
      <a href="https://icp.gov.moe/?keyword=20265535" target="_blank">萌ICP备20265535号</a>
    </footer>
  </body>
</html>
